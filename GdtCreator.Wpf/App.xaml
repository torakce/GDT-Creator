<Application x:Class="GdtCreator.Wpf.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             StartupUri="MainWindow.xaml">
    <Application.Resources>
        <SolidColorBrush x:Key="AppBackgroundBrush" Color="#F3F7FB" />
        <SolidColorBrush x:Key="PanelBackgroundBrush" Color="#FDFEFF" />
        <SolidColorBrush x:Key="PanelBorderBrush" Color="#CAD7E4" />
        <SolidColorBrush x:Key="AccentBrush" Color="#175676" />
        <SolidColorBrush x:Key="AccentSoftBrush" Color="#D9ECF5" />
        <SolidColorBrush x:Key="HeadlineBrush" Color="#102A43" />
        <SolidColorBrush x:Key="BodyBrush" Color="#3C4A57" />
        <SolidColorBrush x:Key="ErrorBrush" Color="#B42318" />
        <SolidColorBrush x:Key="PreviewSurfaceBrush" Color="#FFFFFF" />
        <SolidColorBrush x:Key="SubtleBrush" Color="#8A9BAD" />
        <SolidColorBrush x:Key="SurfaceBrush" Color="#EBF3F9" />
    </Application.Resources>
</Application>
